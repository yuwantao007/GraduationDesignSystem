{
  "name": "complete-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "gen:api": "openapi --input ./openapi.json --output ./src/api/generated --client axios",
    "gen:api:remote": "openapi --input http://localhost:8080/api/v3/api-docs/default --output ./src/api/generated --client axios"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "axios": "^1.13.5",
    "bpmn-js": "^18.13.1",
    "dayjs": "^1.11.19",
    "echarts": "^5.6.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.28",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript-codegen": "^0.30.0",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
