        <omgdi:waypoint x="270" y="245" /><omgdi:waypoint x="270" y="150" /><omgdi:waypoint x="360" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_pre_to_gateway_di" bpmnElement="flow_pre_to_gateway">
        <omgdi:waypoint x="480" y="150" /><omgdi:waypoint x="545" y="150" />
