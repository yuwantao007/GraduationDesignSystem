        <omgdi:waypoint x="480" y="390" /><omgdi:waypoint x="545" y="390" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_init_other_pass_di" bpmnElement="flow_init_other_pass">
        <omgdi:waypoint x="595" y="390" /><omgdi:waypoint x="660" y="390" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_init_other_need_modify_di" bpmnElement="flow_init_other_need_modify">
        <omgdi:waypoint x="570" y="415" /><omgdi:waypoint x="570" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_init_other_modify_resubmit_di" bpmnElement="flow_init_other_modify_resubmit">
        <omgdi:waypoint x="530" y="490" /><omgdi:waypoint x="420" y="490" /><omgdi:waypoint x="420" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_final_other_to_gateway_di" bpmnElement="flow_final_other_to_gateway">
        <omgdi:waypoint x="780" y="390" /><omgdi:waypoint x="845" y="390" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_final_other_pass_di" bpmnElement="flow_final_other_pass">
        <omgdi:waypoint x="895" y="390" /><omgdi:waypoint x="1280" y="390" /><omgdi:waypoint x="1280" y="408" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_final_other_reject_di" bpmnElement="flow_final_other_reject">
        <omgdi:waypoint x="870" y="415" /><omgdi:waypoint x="870" y="450" /><omgdi:waypoint x="1280" y="450" /><omgdi:waypoint x="1280" y="408" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
