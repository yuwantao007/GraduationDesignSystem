      <bpmndi:BPMNShape id="finalUpgradeTask_di" bpmnElement="finalUpgradeTask">
        <omgdc:Bounds x="960" y="120" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="finalUpgradeGateway_di" bpmnElement="finalUpgradeGateway" isMarkerVisible="true">
        <omgdc:Bounds x="1145" y="125" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- 路径B -->
      <bpmndi:BPMNShape id="initOtherTask_di" bpmnElement="initOtherTask">
        <omgdc:Bounds x="360" y="360" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="initOtherGateway_di" bpmnElement="initOtherGateway" isMarkerVisible="true">
        <omgdc:Bounds x="545" y="365" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="initOtherModifyTask_di" bpmnElement="initOtherModifyTask">
        <omgdc:Bounds x="530" y="460" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="finalOtherTask_di" bpmnElement="finalOtherTask">
        <omgdc:Bounds x="660" y="360" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="finalOtherGateway_di" bpmnElement="finalOtherGateway" isMarkerVisible="true">
        <omgdc:Bounds x="845" y="365" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- 结束事件 -->
      <bpmndi:BPMNShape id="passedEndEvent_di" bpmnElement="passedEndEvent">
        <omgdc:Bounds x="1262" y="132" width="36" height="36" />
