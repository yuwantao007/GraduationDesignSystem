      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="categoryGateway_di" bpmnElement="categoryGateway" isMarkerVisible="true">
        <omgdc:Bounds x="245" y="245" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="228" y="302" width="84" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- 路径A -->
      <bpmndi:BPMNShape id="preReviewTask_di" bpmnElement="preReviewTask">
