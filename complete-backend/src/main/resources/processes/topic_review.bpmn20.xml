      </bpmndi:BPMNShape>

      <!-- 连线 -->
      <bpmndi:BPMNEdge id="flow_start_to_gateway_di" bpmnElement="flow_start_to_gateway">
        <omgdi:waypoint x="188" y="270" /><omgdi:waypoint x="245" y="270" />
      </bpmndi:BPMNEdge>
